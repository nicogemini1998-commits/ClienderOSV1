# Docker environment configuration
# Este archivo se usa cuando ejecutas con Docker

# PostgreSQL
POSTGRES_USER=cliender
POSTGRES_PASSWORD=cliender_secure_password_change_me
POSTGRES_DB=cliender_db

# Studio Backend
STUDIO_PORT=3005
STUDIO_NODE_ENV=development
STUDIO_FRONTEND_URL=http://localhost:3005

# LeadUp Backend
LEADUP_PORT=8002
LEADUP_ENVIRONMENT=development
LEADUP_FRONTEND_URL=http://localhost:8002
LEADUP_JWT_SECRET=leadup_secret_jwt_2024_change_this
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
APOLLO_API_KEY=your-apollo-key-here

# Database (internal to Docker network)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cliender_db
