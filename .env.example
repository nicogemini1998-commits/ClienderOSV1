# ClienderOS Environment Configuration
# Copy this to .env and fill in your actual values
# NOTE: Never commit .env to git - only commit .env.example

# API Keys (REQUIRED - Get from your provider accounts)
ANTHROPIC_API_KEY=sk-ant-api03-your-actual-key-here
KIE_API_KEY=your-actual-kie-api-key-here
APOLLO_API_KEY=your-apollo-key-here

# PostgreSQL Database
POSTGRES_USER=cliender
POSTGRES_PASSWORD=change-this-password-in-production
POSTGRES_DB=cliender_db

# Studio Backend
STUDIO_PORT=3005
STUDIO_NODE_ENV=development
STUDIO_FRONTEND_URL=http://localhost:3005

# LeadUp Backend
LEADUP_PORT=8002
LEADUP_ENVIRONMENT=development
LEADUP_FRONTEND_URL=http://localhost:8002
LEADUP_JWT_SECRET=change-this-secret-in-production

# Docker Internal Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cliender_db
DB_USER=cliender
DB_PASSWORD=change-this-password-in-production
