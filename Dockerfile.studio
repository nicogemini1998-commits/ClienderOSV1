# Stage 1: Build React frontend
FROM node:20-alpine AS frontend-builder

WORKDIR /app/frontend

# Copy frontend package files
COPY apps/studio/frontend/package*.json ./

# Install dependencies
RUN npm ci

# Copy frontend source
COPY apps/studio/frontend/ ./

# Build frontend
RUN npm run build

# Stage 2: Runtime - Node.js backend + frontend
FROM node:20-alpine

WORKDIR /app

# Install dumb-init for proper signal handling
RUN apk add --no-cache dumb-init

# Copy backend package files
COPY apps/studio/backend/package*.json ./

# Install backend dependencies
RUN npm ci --only=production

# Copy backend source
COPY apps/studio/backend/ ./

# Copy built frontend from stage 1
COPY --from=frontend-builder /app/frontend/dist ./public

# Expose port
EXPOSE 3005

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3005/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})"

# Use dumb-init to handle signals properly
ENTRYPOINT ["/usr/sbin/dumb-init", "--"]

# Start application
CMD ["node", "server.js"]
